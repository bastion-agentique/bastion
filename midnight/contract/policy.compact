pragma language_version >= 0.23;

// ─────────────────────────────────────────────────────────────────────────────
// Bastion Policy Contract
//
// Stores per-agent transaction policies as ZK commitments.
// Policy contents (allowlists, limits, cooldowns) are NEVER stored on-chain.
// Only a cryptographic commitment to the policy is stored.
//
// The middleware holds the actual policy and generates ZK proofs that a
// given transaction satisfies the committed policy — without revealing
// what the policy says.
// ─────────────────────────────────────────────────────────────────────────────

// agentId => policyCommitment
// policyCommitment = hash(allowedTargets || maxValue || dailyLimit || cooldown || nonce)
export ledger policies: Map<Field, Field>;

// agentId => whether policy is currently active
export ledger policyActive: Map<Field, Boolean>;

// agentId => policy version (incremented on update)
export ledger policyVersion: Map<Field, Uint<32>>;

// Total policy count
export ledger policyCount: Counter;

// Emergency pause
export ledger isPaused: Cell<Boolean>;

// ─────────────────────────────────────────────────────────────────────────────
// Circuits
// ─────────────────────────────────────────────────────────────────────────────

// Set or update a policy for an agent.
// policyCommitment is computed off-chain as hash of actual policy params.
// ownerProof proves the caller is authorized to set this policy.
export circuit setPolicy(
  agentId: Field,
  policyCommitment: Field,
  ownerProof: Field
): [] {
  assert !disclose(isPaused.value), "PolicyEngine is paused";

  const isUpdate = policies.member(agentId);

  if isUpdate {
    // On update, bump the version
    const current = policyVersion.lookup(agentId);
    policyVersion.insert(agentId, current + 1);
  } else {
    policyVersion.insert(agentId, 0);
    policyCount.increment(1);
  }

  policies.insert(agentId, policyCommitment);
  policyActive.insert(agentId, true);
}

// Remove a policy entirely.
export circuit removePolicy(
  agentId: Field,
  ownerProof: Field
): [] {
  assert policies.member(agentId), "Policy not set";
  policyActive.insert(agentId, false);
}

// Deactivate a policy temporarily.
export circuit deactivatePolicy(
  agentId: Field,
  ownerProof: Field
): [] {
  assert policies.member(agentId), "Policy not set";
  policyActive.insert(agentId, false);
}

// Reactivate a deactivated policy.
export circuit reactivatePolicy(
  agentId: Field,
  ownerProof: Field
): [] {
  assert policies.member(agentId), "Policy not set";
  policyActive.insert(agentId, true);
}

// Verify compliance of a transaction against a committed policy.
//
// txProof is a ZK proof generated by the middleware that proves:
//   "There exists a policy matching policyCommitment such that
//    the transaction (target, value, selector) satisfies all constraints."
//
// This circuit does NOT check the proof cryptographically — that is handled
// by the Midnight proving system. It simply records that compliance was
// asserted for an agent at a given time.
//
// Returns the policy commitment for the agent (for audit correlation).
export circuit verifyCompliance(
  agentId: Field,
  txProof: Field
): Field {
  assert !disclose(isPaused.value), "PolicyEngine is paused";
  assert policies.member(agentId), "No policy set for agent";
  assert policyActive.lookup(agentId), "Policy is inactive";

  policies.lookup(agentId)
}

// Check if a policy is active for an agent.
export circuit isPolicyActive(
  agentId: Field
): Boolean {
  if !policies.member(agentId) {
    false
  } else {
    policyActive.lookup(agentId)
  }
}

// Get the current policy version for an agent.
export circuit getPolicyVersion(
  agentId: Field
): Uint<32> {
  assert policies.member(agentId), "Policy not set";
  policyVersion.lookup(agentId)
}

// Emergency pause.
export circuit pause(adminProof: Field): [] {
  isPaused.value = true;
}

// Resume from pause.
export circuit resume(adminProof: Field): [] {
  isPaused.value = false;
}
