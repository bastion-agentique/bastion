# Bastion Sidecar — copy to .env and fill in your values (.env is git-ignored)

# ── Required ──────────────────────────────────────────────────────────────────
# Helius API key for Solana transaction simulation
HELIUS_API_KEY=

# ── Optional auth ─────────────────────────────────────────────────────────────
# Static API key required on every request via X-API-Key header.
# Leave empty to run unauthenticated (local dev).
BASTION_API_KEY=

# ── On-chain audit (Solana devnet) ────────────────────────────────────────────
# BASTION_ON_CHAIN=1
# SOLANA_RPC_URL=https://api.devnet.solana.com
# BASTION_KEYPAIR_PATH=~/.config/solana/id.json

# ── Optional integrations ─────────────────────────────────────────────────────
# GROND_API_URL=        # GrondOSINT address risk oracle
# CELO_RPC_URL=         # EVM/Celo transaction simulation
# ALCHEMY_API_KEY=      # Alchemy Solana simulator (alternative to Helius)
