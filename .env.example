# Bastion Sidecar Environment Variables
# Copy this to .env and fill in your values. .env is git-ignored.
# Auth: removed in v0.3.1 — pay.sh handles auth via payment verification.
# x402 on MCP server handles tool payment. The sidecar REST API is open.

# Helius API key for Solana transaction simulation
HELIUS_API_KEY=

# Enable on-chain audit logging (Solana devnet)
# BASTION_ON_CHAIN=1
# SOLANA_RPC_URL=https://api.devnet.solana.com
# BASTION_KEYPAIR_PATH=~/.config/solana/dev.json

# Grond OSINT oracle for address risk scoring
# GROND_API_URL=

# Celo/EVM simulator
# CELO_RPC_URL=
